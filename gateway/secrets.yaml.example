# secrets.yaml.example — copy to secrets.yaml and fill in your API key
#
# secrets.yaml is gitignored. Never commit it.
#
# apply-config.sh reads this file and injects the key into openclaw.json
# inside the running Docker volume — the key is never stored on the host filesystem.

anthropic_api_key: REPLACE_ME   # sk-ant-...

# For OpenAI instead of Anthropic, see apply-config.sh for the provider format.
