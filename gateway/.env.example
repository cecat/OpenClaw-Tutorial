# .env — Gateway environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Your Tailscale IP address (find with: tailscale ip -4)
TAILSCALE_IP=x.x.x.x

# Absolute path to your agent workspace directory
# All agents live under this directory; it is the only host path agents can access.
OPENCLAW_WORKSPACE=/home/youruser/openclaw-workspace

# Your home directory (used for credential bind mounts when integrations are added)
USER_HOME=/home/youruser

# Docker group GID (find with: getent group docker | cut -d: -f3)
DOCKER_GID=988
